<idea-plugin>
    <actions>
        <action id="com.github.nikolaborisov04.semanticidentifiers.actions.SuggestNameAction"
                class="com.github.nikolaborisov04.semanticidentifiers.actions.SuggestNameAction"
                text="Suggest Semantic Name"
                description="AI-powered variable naming based on context">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift S"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <intentionAction>
            <className>com.github.nikolaborisov04.semanticidentifiers.intentions.SuggestNameIntention</className>
            <category>Semantic Identifiers</category>
            <skipBeforeAfter>true</skipBeforeAfter>
        </intentionAction>
        <applicationConfigurable
            parentId="tools"
            instance="com.github.nikolaborisov04.semanticidentifiers.settings.SettingsConfigurable"
            id="com.github.nikolaborisov04.semanticidentifiers.settings.SettingsConfigurable"
            displayName="Semantic Identifiers"/>
    </extensions>
</idea-plugin>